# Database
DB_HOST=db
DB_USER=root
DB_PASSWORD=mangocek_root
DB_NAME=mangocek_db

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret (ganti dengan string acak yang panjang di production)
JWT_SECRET=ganti_dengan_secret_yang_kuat_di_production

# ML Service URL (diisi otomatis oleh docker-compose; kosongkan untuk fallback subprocess)
ML_SERVICE_URL=

# GCP Cloud Storage (opsional — kosongkan untuk menonaktifkan)
GCS_BUCKET_NAME=
GCS_KEY_FILE=/app/gcs-key.json
